# ---- Relay (OpenAI-compatible) ----
# The endpoint your backend calls. The relay serves the OpenAI /v1/chat/completions API.
RELAY_BASE_URL=https://jingyuqingfeng.cn/v1
# Your relay token. KEEP THIS SECRET. Never commit this file.
RELAY_API_KEY=sk-replace-with-your-token
# Default model. Relay offers: gpt-5.4-mini, gpt-5.4, gpt-5.5, gpt-4o, etc.
DEFAULT_MODEL=gpt-5.4-mini

# ---- Auth ----
# Secret used to sign JWTs. Change to a long random string in production.
JWT_SECRET=change-me-to-a-long-random-string

# ---- Server ----
PORT=8787
